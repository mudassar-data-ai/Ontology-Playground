    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/curriculum_curriculumName">
        <rdfs:label>curriculumName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Curriculum"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Required non-key attribute for Curriculum.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/curriculum_completionRule">
        <rdfs:label>completionRule</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Curriculum"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Required non-key attribute for Curriculum.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/curriculum_validFrom">
        <rdfs:label>validFrom</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Curriculum"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Required non-key attribute for Curriculum.</rdfs:comment>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/curriculum_validTo">
        <rdfs:label>validTo</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Curriculum"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Required non-key attribute for Curriculum.</rdfs:comment>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/course_courseId">
        <rdfs:label>courseId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Course"/>
