    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/skill_skillName">
        <rdfs:label>skillName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Skill"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Required non-key attribute for Skill.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/skill_skillCategory">
        <rdfs:label>skillCategory</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Skill"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Required non-key attribute for Skill.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/learning-ontology/hasCurriculum">
        <rdfs:label>hasCurriculum</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/LearningProgram"/>
        <rdfs:range rdf:resource="http://example.org/ontology/learning-ontology/Curriculum"/>
        <rdfs:comment>Links a learning program to a curriculum that belongs to it.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>learningProgram</ont:fromEntityId>
        <ont:toEntityId>curriculum</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/learning-ontology/partOfProgram">
        <rdfs:label>partOfProgram</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Curriculum"/>
        <rdfs:range rdf:resource="http://example.org/ontology/learning-ontology/LearningProgram"/>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>curriculum</ont:fromEntityId>
        <ont:toEntityId>learningProgram</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/learning-ontology/containsCourse">
        <rdfs:label>containsCourse</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Curriculum"/>
        <rdfs:range rdf:resource="http://example.org/ontology/learning-ontology/Course"/>
        <rdfs:comment>Links a curriculum to courses that satisfy its structure.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>curriculum</ont:fromEntityId>
        <ont:toEntityId>course</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/learning-ontology/partOfCurriculum">
        <rdfs:label>partOfCurriculum</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Course"/>
        <rdfs:range rdf:resource="http://example.org/ontology/learning-ontology/Curriculum"/>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>course</ont:fromEntityId>
        <ont:toEntityId>curriculum</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/learning-ontology/includesLearningItem">
        <rdfs:label>includesLearningItem</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Course"/>
        <rdfs:range rdf:resource="http://example.org/ontology/learning-ontology/LearningItem"/>
        <rdfs:comment>Links a course to one or more learning items that are delivered as part of the course.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>course</ont:fromEntityId>
        <ont:toEntityId>learningItem</ont:toEntityId>
    </owl:ObjectProperty>

