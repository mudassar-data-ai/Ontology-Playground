        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Required non-key attribute for LearningCompletion.</rdfs:comment>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/learningCompletion_score">
        <rdfs:label>score</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/LearningCompletion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Required non-key attribute for LearningCompletion.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/learningCompletion_attemptNumber">
        <rdfs:label>attemptNumber</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/LearningCompletion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Optional non-key attribute for LearningCompletion representing retry count.</rdfs:comment>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/skill_skillId">
        <rdfs:label>skillId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Skill"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Key attribute for Skill.</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>integer</ont:propertyType>
