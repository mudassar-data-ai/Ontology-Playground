<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/learning-ontology/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/learning-ontology/">

    <owl:Ontology rdf:about="http://example.org/ontology/learning-ontology/">
        <rdfs:label>Learning Ontology</rdfs:label>
        <rdfs:comment>Canonical learning ontology derived from the reference model in clean_with_keys_and_attributes.owl. It defines business entities, explicit key attributes, required non-key attributes, and core relationships for a learning domain.</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/learning-ontology/Person">
        <rdfs:label>Person</rdfs:label>
        <rdfs:comment>A learner or worker participating in learning programs, assignments, completions, and skill tracking.</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/learning-ontology/LearningProgram">
        <rdfs:label>LearningProgram</rdfs:label>
        <rdfs:comment>A structured learning offering that can group curricula and coordinate mandatory or optional development activities.</rdfs:comment>
        <ont:icon>🎓</ont:icon>
        <ont:color>#008272</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/learning-ontology/Curriculum">
        <rdfs:label>Curriculum</rdfs:label>
        <rdfs:comment>A rules-based grouping of courses or learning items with an effective validity period and completion requirements.</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#E81123</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/learning-ontology/Course">
        <rdfs:label>Course</rdfs:label>
        <rdfs:comment>A formal course container with a delivery model and duration measured in hours.</rdfs:comment>
        <ont:icon>📚</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/learning-ontology/LearningItem">
        <rdfs:label>LearningItem</rdfs:label>
        <rdfs:comment>An atomic learning resource such as a module, class, video, assessment, or external content item.</rdfs:comment>
        <ont:icon>📄</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/learning-ontology/LearningAssignment">
        <rdfs:label>LearningAssignment</rdfs:label>
        <rdfs:comment>An assignment of a learning item to a person, including business reason and required completion dates.</rdfs:comment>
        <ont:icon>📝</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/learning-ontology/LearningCompletion">
        <rdfs:label>LearningCompletion</rdfs:label>
        <rdfs:comment>A completion event for a learning item or assignment, including status, date, score, and optional attempt number.</rdfs:comment>
        <ont:icon>✅</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/learning-ontology/Skill">
        <rdfs:label>Skill</rdfs:label>
        <rdfs:comment>A capability, competency, or skill domain that can be developed by learning and associated with a person.</rdfs:comment>
        <ont:icon>🎯</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/person_personId">
        <rdfs:label>personId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Key attribute for Person.</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/person_userName">
        <rdfs:label>userName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Required non-key attribute for Person.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/person_email">
        <rdfs:label>email</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Required non-key attribute for Person.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/person_jobRole">
        <rdfs:label>jobRole</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Required non-key attribute for Person.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/person_employmentStatus">
        <rdfs:label>employmentStatus</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Person"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Required non-key attribute for Person.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/learningProgram_programId">
        <rdfs:label>programId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/LearningProgram"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Key attribute for LearningProgram.</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/learningProgram_programName">
        <rdfs:label>programName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/LearningProgram"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Required non-key attribute for LearningProgram.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/learningProgram_programType">
        <rdfs:label>programType</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/LearningProgram"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Required non-key attribute for LearningProgram.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/learningProgram_isMandatory">
        <rdfs:label>isMandatory</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/LearningProgram"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Required non-key attribute for LearningProgram.</rdfs:comment>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/curriculum_curriculumId">
        <rdfs:label>curriculumId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/Curriculum"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Key attribute for Curriculum.</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
