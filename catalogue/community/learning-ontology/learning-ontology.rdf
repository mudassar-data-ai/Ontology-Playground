        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Required non-key attribute for LearningItem.</rdfs:comment>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/learningAssignment_assignmentId">
        <rdfs:label>assignmentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/LearningAssignment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Key attribute for LearningAssignment.</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/learningAssignment_assignmentReason">
        <rdfs:label>assignmentReason</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/LearningAssignment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Required non-key attribute for LearningAssignment.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/learningAssignment_assignedDate">
        <rdfs:label>assignedDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/LearningAssignment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Required non-key attribute for LearningAssignment.</rdfs:comment>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/learningAssignment_dueDate">
        <rdfs:label>dueDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/LearningAssignment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Required non-key attribute for LearningAssignment.</rdfs:comment>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/learningCompletion_completionId">
        <rdfs:label>completionId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/LearningCompletion"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Key attribute for LearningCompletion.</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/learning-ontology/learningCompletion_completionStatus">
        <rdfs:label>completionStatus</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/learning-ontology/LearningCompletion"/>
